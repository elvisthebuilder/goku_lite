[Unit]
Description=Goku Lite AI Orchestrator
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/goku-lite
Environment="PATH=/opt/goku-lite/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
ExecStart=/opt/goku-lite/venv/bin/python main.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
