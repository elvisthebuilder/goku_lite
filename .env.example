# Goku Lite - Cloud-Native Configuration

# 1. Intelligence (Cloud LLM)
# Use OpenAI, Anthropic, Gemini, or any LiteLLM compatible endpoint
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOKU_MODEL=gpt-4o-mini

# 2. Memory (Qdrant Cloud)
# Get your free cluster at https://cloud.qdrant.io/
QDRANT_URL=https://your-cluster-url.aws.cloud.qdrant.io
QDRANT_API_KEY=your-api-key

# 3. Logs & History (External Database)
# Support for PostgreSQL (Supabase/Neon recommended)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# 4. Channels
TELEGRAM_BOT_TOKEN=
GOKU_OWNER_ID= # Your Telegram/WhatsApp ID for exclusive control

# 5. Tools & Skills
TAVILY_API_KEY= # Get your free search API key at tavily.com

# 6. Security
API_SECRET_KEY= # For securing the web dashboard
